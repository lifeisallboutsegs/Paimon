# Copy this file to .env and fill in your values. Never commit .env.

# Get this from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=your_bot_token_here

# Default command prefix (servers can override this with /config prefix)
DEFAULT_PREFIX=!

# Comma-separated Discord user IDs who can use owner-only commands (cogs/admin.py)
OWNER_IDS=123456789012345678

# "sqlite" (recommended, relational, default) or "json" (zero-dependency, flat files)
DATABASE_BACKEND=sqlite

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
GROQ_API_KEY=your_groq_api_key_here,your_groq_api_key_here_2
OPENWEATHER_API_KEY=your_openweather_api_key_here